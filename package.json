{
  "name": "winserv-monitoring",
  "version": "1.0.0",
  "description": "Remote monitoring for Windows Server hosts and VMs",
  "scripts": {
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "setup": "npm run install:backend; npm run install:frontend; npm run build:frontend"
  },
  "keywords": ["monitoring", "windows", "server"],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
